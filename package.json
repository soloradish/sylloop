{
  "name": "sylloop",
  "private": true,
  "version": "0.5.1",
  "license": "MIT",
  "engines": {
    "node": "24.16.0"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:tauri": "npm run ffmpeg:prepare && npm run build",
    "ffmpeg:prepare": "node scripts/prepare-ffmpeg.mjs",
    "test": "vitest run",
    "version:set": "node scripts/version.mjs set",
    "version:check": "node scripts/version.mjs check",
    "release:manifest": "node scripts/release-manifest.mjs",
    "test:e2e:tauri": "wdio run wdio.conf.ts",
    "test:fixtures": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/prepare-test-fixtures.ps1",
    "build:e2e": "npm run ffmpeg:prepare && npm run test:fixtures && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-e2e.ps1",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-opener": "2.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "overrides": {
    "@wdio/native-utils": "2.5.0",
    "serialize-javascript": "7.0.5"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@wdio/cli": "9.29.1",
    "@wdio/local-runner": "9.29.1",
    "@wdio/mocha-framework": "9.29.1",
    "@wdio/tauri-plugin": "1.2.0",
    "@wdio/tauri-service": "1.2.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
