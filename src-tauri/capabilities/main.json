{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Minimum permissions for the main player window",
  "windows": ["main"],
  "permissions": [
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "dialog:allow-open",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://github.com/soloradish/echo-player/issues/new*" },
        { "url": "https://lowid.me/zh/echo-player/" },
        { "url": "https://lowid.me/en/echo-player/" }
      ]
    }
  ]
}
