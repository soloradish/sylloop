{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sylloop",
  "version": "0.3.0",
  "identifier": "io.github.soloradish.sylloop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:tauri",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Sylloop",
        "width": 1180,
        "height": 760,
        "minWidth": 780,
        "minHeight": 560,
        "center": true,
        "dragDropEnabled": true,
        "backgroundColor": "#111310"
      }
    ],
    "security": {
      "csp": "default-src 'self' asset: http://asset.localhost; media-src 'self' asset: http://asset.localhost blob:; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": []
      },
      "capabilities": [
        "main-capability"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "shortDescription": "A focused player for listening and repetition",
    "resources": [
      "resources/ffmpeg.exe",
      "resources/FFMPEG_LICENSE.txt"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
